NODE_ENV=development
PORT=3001
MONGO_URI=mongodb://localhost:27017/mams_dev
# Atlas example (replace host/user/pass/db; URL-encode special chars in password):
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/mams_dev?retryWrites=true&w=majority
JWT_ACCESS_SECRET=replace-me-with-openssl-rand-base64-32
JWT_REFRESH_SECRET=replace-me-with-openssl-rand-base64-32
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=debug
TZ=Asia/Kolkata
SMART_ANCHOR_VERSION=v2.0.0

# Optional — seed users (`npm run seed`). Login always uses MongoDB; these only control what seed inserts.
# SEED_HR_ADMIN_EMAIL=hr.admin@makson-group.com
# SEED_HR_COMPLIANCE_EMAIL=hr.compliance@makson-group.com
# SEED_DEFAULT_PASSWORD=makson2026
# SEED_HR_ADMIN_NAME=Priya Patel
# SEED_HR_COMPLIANCE_NAME=Compliance Auditor

# Welcome email (NodeMailer) — set MAIL_ENABLED=true when SMTP is available
MAIL_ENABLED=false
# APP_PUBLIC_URL=http://localhost:5173
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=MAMS <noreply@makson-group.com>
