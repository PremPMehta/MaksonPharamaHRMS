### MAMS Nginx config (sample) - place at /etc/nginx/sites-available/mams.conf
### Symlink to /etc/nginx/sites-enabled/ and reload nginx.

upstream mams_backend {
    server 127.0.0.1:3001;
    keepalive 32;
}

server {
    listen 80;
    server_name mams.makson.local;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name mams.makson.local;

    # TLS - replace with your certs (Let's Encrypt or self-signed for local).
    ssl_certificate     /etc/ssl/certs/mams.crt;
    ssl_certificate_key /etc/ssl/private/mams.key;
    ssl_protocols       TLSv1.2 TLSv1.3;

    # Security headers - helmet sets some, this layer adds defence in depth.
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    # General rate limit (10 req/sec per IP, burst 100).
    limit_req_zone $binary_remote_addr zone=mams_general:10m rate=10r/s;

    client_max_body_size 5m;

    # Static SPA assets (built mams-web).
    root /opt/mams/current/mams-web/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # API.
    location /api/ {
        limit_req zone=mams_general burst=100 nodelay;
        proxy_pass http://mams_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # eSSL ADMS receiver. Devices send text/plain bodies.
    # Note: no rate limit here - bursts of 100K records on reconnect are legitimate.
    location /iclock/ {
        proxy_pass http://mams_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_request_buffering off;
        client_body_buffer_size 1m;
        proxy_read_timeout 60s;
    }
}
